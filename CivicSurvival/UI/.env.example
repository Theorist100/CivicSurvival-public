# Sentry DSN — runtime SDK ingest key (public, write-only) from your sentry.io project.
# Injected into the client at build time via webpack DefinePlugin. Leave empty to build
# with crash reporting disabled (the public repo ships no DSN).
SENTRY_DSN=

# Sentry source-map upload (release builds only).
# Copy to .env (gitignored) and fill in real values from sentry.io.
# When ANY of these is missing, webpack skips the upload step entirely and
# the build behaves exactly as before — the SDK still works at runtime,
# stack traces just stay minified in the Sentry dashboard.

SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
